PCF_PORT=3791
PCF_HOST=127.0.0.1
PCF_WEBHOOK_SECRET=replace-with-github-webhook-secret

# Keep dry-run true until the GitHub App is installed and tested.
PCF_DRY_RUN=true
PCF_POST_COMMENTS=false
PCF_APPLY_LABELS=false
PCF_COLLECT_REPOSITORY_CONTEXT=true
PCF_UPSTREAM_REPOSITORY=
PCF_GITHUB_QUEUE_LIMIT=25
PCF_GITHUB_CACHE_TTL_MS=60000
PCF_GITHUB_SEARCH_DELAY_MS=2000
PCF_QUEUE_HISTORY_ENABLED=true
PCF_QUEUE_HISTORY_PATH=
PCF_QUEUE_HISTORY_LIMIT=50
PCF_FEEDBACK_ENABLED=true
PCF_FEEDBACK_PATH=
PCF_FEEDBACK_LIMIT=200

# Required for authenticated GitHub App reads and any later explicit write upgrade.
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_API_BASE=https://api.github.com
